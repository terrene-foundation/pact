# PACT Web Dashboard -- Environment Variables
# Copy this file to .env.local and fill in your values.

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------

# PACT API URL (defaults to http://localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Static API token for CLI/API-only access (optional when using Firebase SSO)
# NEXT_PUBLIC_API_TOKEN=

# ---------------------------------------------------------------------------
# Firebase Authentication (optional -- enables Google & GitHub SSO)
# ---------------------------------------------------------------------------
# When these are not set, the dashboard falls back to static token auth.

# Firebase project API key (from Firebase Console > Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase Auth domain (typically: <project-id>.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=terrene-care.firebaseapp.com

# Firebase project ID (matches GCP project ID)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=terrene-care
