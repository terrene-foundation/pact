# ============================================================
# CARE Platform - Environment Configuration Template
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================

# ── LLM Configuration ───────────────────────────────────────
# At minimum, configure ONE provider with its API key and model.

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_PROD_MODEL=gpt-4o
# OPENAI_DEV_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google (Gemini)
# GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# ── Default Model ───────────────────────────────────────────
# Fallback model used when no specific model is configured.
# DEFAULT_LLM_MODEL=gpt-4o

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/care_platform
# REDIS_URL=redis://localhost:6379/0
# POSTGRES_PASSWORD=your-strong-password-here  # Required for docker compose

# ── EATP Trust Configuration ──────────────────────────────
# EATP_GENESIS_AUTHORITY=terrene.foundation
# EATP_CREDENTIAL_TTL_SECONDS=300

# ── CARE Platform API ─────────────────────────────────────
# CARE_API_TOKEN=your-secure-token-here
# CARE_API_HOST=0.0.0.0
# CARE_API_PORT=8000
# CARE_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# CARE_MAX_WS_SUBSCRIBERS=50
# CARE_DEV_MODE=true  # Set to true to allow empty CARE_API_TOKEN

# ── Application ─────────────────────────────────────────────
# APP_ENV=development
# DEBUG=true
# LOG_LEVEL=INFO
