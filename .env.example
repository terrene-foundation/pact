# ============================================================
# PACT - Environment Configuration Template
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================

# ── LLM Configuration ───────────────────────────────────────
# At minimum, configure ONE provider with its API key and model.

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_PROD_MODEL=gpt-4o
# OPENAI_DEV_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google (Gemini)
# GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# ── Default Model ───────────────────────────────────────────
# Fallback model used when no specific model is configured.
# DEFAULT_LLM_MODEL=gpt-4o

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/pact
# REDIS_URL=redis://localhost:6379/0
# POSTGRES_PASSWORD=your-strong-password-here  # Required for docker compose

# ── EATP Trust Configuration ──────────────────────────────
# EATP_GENESIS_AUTHORITY=terrene.foundation
# EATP_CREDENTIAL_TTL_SECONDS=300

# ── PACT API ─────────────────────────────────────────────
# PACT_API_TOKEN=your-secure-token-here
# PACT_API_HOST=0.0.0.0
# PACT_API_PORT=8000
# PACT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# PACT_MAX_WS_SUBSCRIBERS=50
# PACT_DEV_MODE=true  # Set to true to allow empty PACT_API_TOKEN
# PACT_RATE_LIMIT_GET=60/minute    # Rate limit for GET endpoints
# PACT_RATE_LIMIT_POST=10/minute   # Rate limit for POST endpoints
# PACT_MAX_BODY_SIZE=1048576       # Max request body size in bytes (default: 1MB)

# ── LLM Pricing Override ─────────────────────────────────────
# Override default per-model pricing (USD per million tokens).
# JSON string with 'openai' and/or 'anthropic' keys.
# PACT_LLM_PRICING_JSON={"openai":{"gpt-4o":{"input":"2.5","output":"10.0"}},"anthropic":{"claude-sonnet-4":{"input":"3.0","output":"15.0"}}}

# ── Logging ─────────────────────────────────────────────────
# PACT_LOG_FORMAT=console  # 'console' for dev (human-readable), 'json' for production

# ── Firebase Authentication (Web Dashboard) ─────────────────
# Required for Google & GitHub SSO in the web frontend.
# Without these, the dashboard falls back to static token auth.
# NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ── Application ─────────────────────────────────────────────
# APP_ENV=development
# DEBUG=true
# LOG_LEVEL=INFO
